# ═══════════════════════════════════════════════════════════════════════════
# MINIMUM TO RUN THE APP — just these two:
# ═══════════════════════════════════════════════════════════════════════════
GEMINI_API_KEY=ADD_API_HERE       # required — powers intent routing, narration, review summaries
SERP_API_KEY=ADD_API_HERE            # required for product search — Google Shopping results
                                      # covers Amazon/Flipkart/most Indian retailers via one key.
                                      # Get one free at https://serpapi.com (no separate "base URL" needed)

# Everything below is OPTIONAL. The app works fully with just the two keys
# above. Each section below adds one more platform on top of SerpAPI results,
# but every one of them needs its OWN partner/affiliate account — there is no
# universal "shopping API key" that unlocks all of these at once. Leave any
# section as ADD_API_HERE and that platform is simply skipped.

# ─── E-commerce Affiliate APIs (optional) ────────────────────────────────────
# Amazon PA-API — requires an approved Amazon Associates account first.
AMAZON_AFFILIATE_TAG=ADD_API_HERE
AMAZON_ACCESS_KEY=ADD_API_HERE
AMAZON_SECRET_KEY=ADD_API_HERE
AMAZON_PARTNER_TAG=ADD_API_HERE

# Flipkart Affiliate API — requires an approved Flipkart Affiliate account.
FLIPKART_AFFILIATE_ID=ADD_API_HERE
FLIPKART_AFFILIATE_TOKEN=ADD_API_HERE

# Myntra / Ajio — via Admitad or VCommission affiliate networks.
# Each needs BOTH a token AND your personal feed URL from that dashboard.
MYNTRA_AFFILIATE_TOKEN=ADD_API_HERE
MYNTRA_FEED_URL=ADD_API_HERE
AJIO_AFFILIATE_TOKEN=ADD_API_HERE
AJIO_FEED_URL=ADD_API_HERE
NYKAA_AFFILIATE_TOKEN=ADD_API_HERE

# ─── Quick Commerce APIs (optional, usually unavailable to individuals) ──────
# Blinkit, Zepto, Instamart and Zomato have NO public self-serve APIs.
# These only work if you have a private partnership or a licensed
# third-party data provider — most users will never have working values
# here, and that's fine: the app runs normally without them.
BLINKIT_API_KEY=ADD_API_HERE
BLINKIT_API_BASE_URL=ADD_API_HERE

ZEPTO_API_KEY=ADD_API_HERE
ZEPTO_API_BASE_URL=ADD_API_HERE

INSTAMART_API_KEY=ADD_API_HERE       # Swiggy Instamart
INSTAMART_API_BASE_URL=ADD_API_HERE

ZOMATO_API_KEY=ADD_API_HERE
ZOMATO_API_BASE_URL=ADD_API_HERE

# ─── Cache (Redis — optional; app falls back to in-memory if not set) ─────────
REDIS_URL=redis://localhost:6379/0

# ─── App Settings ─────────────────────────────────────────────────────────────
APP_ENV=development                  # development | production
APP_SECRET_KEY=ADD_API_HERE          # random secret for session tokens
SESSION_TTL_SECONDS=3600             # 1 hour session lifetime
CACHE_TTL_SECONDS=300                # 5 min product cache

# ─── Rate Limits ──────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30
MAX_SEARCH_PLATFORMS=6               # how many platforms to hit in parallel

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
